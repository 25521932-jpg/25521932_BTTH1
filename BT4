#include <iostream>
using namespace std;

class Date {
public:
    int d,m,y;

    void nhap() {
        cin >> d >> m >> y;
    }

    int soNgay(int m, int y) {
        if (m==2) return (y%4==0 && y%100!=0)||(y%400==0)?29:28;
        if (m==4||m==6||m==9||m==11) return 30;
        return 31;
    }

    void nextDay() {
        d++;
        if (d > soNgay(m,y)) {
            d=1; m++;
            if (m>12){m=1;y++;}
        }
    }

    void xuat() {
        cout << d << "/" << m << "/" << y;
    }
};

int main(){
    Date a;
    a.nhap();
    a.nextDay();
    a.xuat();
}